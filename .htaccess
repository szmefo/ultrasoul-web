# UltraSoulAI static bridge — Hostido Apache config
# Maps clean URLs (/privacy, /terms) to .html files — stable URLs per privacy policy sec. 12

Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If request is for a real file or directory, serve it as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, try adding .html extension
  RewriteRule ^([^.]+)$ $1.html [L]
</IfModule>

# Redirect .html URLs to clean URLs (preserves stable /privacy address)
<IfModule mod_rewrite.c>
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# Cache HTML briefly (allows content updates to propagate)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

ErrorDocument 404 /index.html
